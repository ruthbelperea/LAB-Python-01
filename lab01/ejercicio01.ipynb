#punto 4 del punto 1
punto = (3, 7)

print(punto)

# Rectángulo
rectangulo = (10, 5)

ancho = rectangulo[0]
alto = rectangulo[1]

# Área
area = ancho * alto

# Perímetro
perimetro = 2 * (ancho + alto)

print("Área:", area)
print("Perímetro:", perimetro)

#la distancia total recorrida dadas las posiciones anteriores
posiciones = [(0, 0), (1, 2), (3, 4)]

distancia = 0

for i in range(len(posiciones)-1):

    x1 = posiciones[i][0]
    y1 = posiciones[i][1]

    x2 = posiciones[i+1][0]
    y2 = posiciones[i+1][1]

    distancia += ((x2 - x1)**2 + (y2 - y1)**2) ** 0.5

print("Distancia:", distancia)



