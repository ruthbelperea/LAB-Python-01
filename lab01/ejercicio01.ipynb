# punto 5 del punto 1
biblioteca = {
    "libros": [
        {"titulo": "1984", "autor": "George Orwell", "prestado": False},
        {"titulo": "El Principito", "autor": "Antoine de Saint-Exupéry", "prestado": True},
    ],
    "usuarios": ["Ana", "Luis", "María"]
}

prestados = 0
disponibles = 0

for libro in biblioteca["libros"]:

    if libro["prestado"] == True:
        prestados += 1
    else:
        disponibles += 1

print("Prestados:", prestados)
print("Disponibles:", disponibles)

# Agregar libro
biblioteca["libros"].append({
    "titulo": "Don Quijote",
    "autor": "Cervantes",
    "prestado": False
})

# Prestar 1984
for libro in biblioteca["libros"]:

    if libro["titulo"] == "1984":
        libro["prestado"] = True

# Mostrar biblioteca
print(biblioteca)
