# punto 3 del punto 1
inventario = [
    {"nombre": "Pan", "precio": 1500, "stock": 30},
    {"nombre": "Leche", "precio": 3500, "stock": 15},
    {"nombre": "Café", "precio": 8000, "stock": 10},
]

# Primer producto
print(inventario[0]["nombre"])

# Agregar producto
inventario.append({
    "nombre": "Arroz",
    "precio": 4000,
    "stock": 20
})

# Restar stock
inventario[1]["stock"] -= 2

# Valor total
total = 0

for p in inventario:
    total += p["precio"] * p["stock"]

print("Valor total:", total)

# Stock menor a 10
for p in inventario:
    if p["stock"] < 10:
        print(p)

# Aumentar precios
for p in inventario:
    p["precio"] = p["precio"] * 1.10
    p["precio"] = round(p["precio"], 2)

# Buscar producto
buscar = input("Ingrese producto: ")

encontrado = False

for p in inventario:
    if p["nombre"].lower() == buscar.lower():
        print(p)
        encontrado = True

if encontrado == False:
    print("No encontrado")

# Eliminar stock 0
for p in inventario:
    if p["stock"] == 0:
        inventario.remove(p)

# Ordenar por precio
inventario.sort(key=lambda x: x["precio"])

print(inventario)




