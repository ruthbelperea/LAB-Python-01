# punto 2  del punto 1
temperaturas = [22.5, 23.0, 21.8, 24.3, 25.1]

print(temperaturas)

# Agregar temperatura
temperaturas.append(23.7)

# Eliminar primera
temperaturas.pop(0)

# Insertar en segunda posición
temperaturas.insert(1, 22.9)

# Ordenar
temperaturas.sort()

print("Ordenadas:", temperaturas)

# Diferencia
diferencia = max(temperaturas) - min(temperaturas)

# Promedio
promedio = sum(temperaturas) / len(temperaturas)

print("Diferencia:", diferencia)
print("Promedio:", promedio)

# Índice
print("Posición de 23.7:", temperaturas.index(23.7))

# Posiciones 2 a 4
print(temperaturas[1:4])

# Primeras tres
print(temperaturas[:3])



