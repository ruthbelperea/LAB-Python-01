# punto 4 del ejercico 2
suma_pares = 0
suma_impares = 0
for i in range(1, 11):

    if i % 2 == 0:
        suma_pares += i
    else:
        suma_impares += i
print("Pares:", suma_pares)
print("Impares:", suma_impares)

# Estado final
estado = {
    "suma_pares": suma_pares,
    "suma_impares": suma_impares}
print(estado)

#---------------------------------------------------------
# punto 5 del ejercico 2
productos = []

while True:

    nombre = input("Ingrese producto (o 'fin'): ")

    if nombre == "fin":
        break

    precio = float(input("Precio: "))
    cantidad = int(input("Cantidad: "))

    # Saltar datos inválidos
    if precio < 0 or cantidad < 0:
        continue

    productos.append({
        "nombre": nombre,
        "precio": precio,
        "cantidad": cantidad})

# Total
total = 0
for p in productos:
    total += p["precio"] * p["cantidad"]
print("Total:", total)

# Producto más caro
mas_caro = max(productos, key=lambda x: x["precio"])
print("Producto más caro:")
print(mas_caro)

# Estado final
print(productos)
