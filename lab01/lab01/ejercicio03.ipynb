# parte 1 ejercio 3 
# import requests

url = "https://jsonplaceholder.typicode.com/users"
response = requests.get(url)
usuarios = response.json()

print("Usuarios con correo .biz:")

# Procesamiento con filtrado
for u in usuarios:
    if u["email"].endswith(".biz"):
        print(f"- {u['name']} (Email: {u['email']})")

# parte 2 ejercicio 3
import requests

nombre_pokemon = input("Ingrese el nombre de un Pokémon: ").lower()
url = f"https://pokeapi.co/api/v2/pokemon/{nombre_pokemon}"
respuesta = requests.get(url)

if respuesta.status_code == 200:
    datos = respuesta.json()

    # Modelado extendido
    pokemon = {
        "nombre": datos["name"],
        "altura": datos["height"],
        "peso": datos["weight"],
        "tipos": [t["type"]["name"] for t in datos["types"]],
        "habilidades": [h["ability"]["name"] for h in datos["abilities"]],
        "imagen": datos["sprites"]["front_default"] # Dato extra interesante
    }

    print("\n📘 Información del Pokémon")
    print(f"Nombre: {pokemon['nombre'].capitalize()}")
    
    # 1. Condicional para tipos
    if len(pokemon["tipos"]) > 1:
        print("Estado: Pokémon de tipo mixto")
    else:
        print(f"Tipo: {pokemon['tipos'][0]}")

    # 2. Condicional para peso
    if pokemon["peso"] > 100:
        print("Categoría: Pokémon de gran tamaño")
    else:
        print("Categoría: Pokémon ligero")

    # 3. Listar habilidades una por una con for
    print("\nHabilidades disponibles:")
    for habilidad in pokemon["habilidades"]:
        print(f"  • {habilidad.replace('-', ' ').capitalize()}")

    # Uso interesante: URL de la imagen
    if pokemon["imagen"]:
        print(f"\n📸 Puedes ver su imagen en: {pokemon['imagen']}")

else:
    print("Pokémon no encontrado. Verifique el nombre ingresado.")
